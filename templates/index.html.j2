<!DOCTYPE html>
<html lang="{{ lang | default('en') }}">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ person.name }}</title>
  <style>
    /* ── Reset & tokens ─────────────────────────────────────────── */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --accent:   #0ea5e9;   /* sky-500  */
      --accent-d: #0369a1;   /* sky-700  */
      --hero-bg:  #0f172a;   /* slate-900 */
      --hero-fg:  #f1f5f9;   /* slate-100 */
      --pill-bg:  #dbeafe;   /* blue-100 */
      --pill-fg:  #1e3a8a;   /* blue-900 */
      --body-bg:  #f8fafc;   /* slate-50 */
      --text:     #1e293b;   /* slate-800 */
      --muted:    #64748b;   /* slate-500 */
      --border:   #e2e8f0;   /* slate-200 */
    }

    body {
      font-family: sans-serif;
      font-size: 16px;
      line-height: 1.55;
      color: var(--text);
      background: var(--body-bg);
    }

    a { color: var(--accent-d); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── Hero ───────────────────────────────────────────────────── */
    #hero {
      background: var(--hero-bg);
      color: var(--hero-fg);
      padding: 0 20px;
    }

    #hero-inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 22px 0 36px;
    }

    /* nav inside hero */
    #topnav {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: .82rem;
      color: #94a3b8;       /* slate-400 */
      margin-bottom: 32px;
    }

    #topnav .nav-links { display: flex; gap: 10px; }

    #topnav a {
      color: #94a3b8;
      text-decoration: none;
      font-size: .78rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      transition: color .15s, border-color .15s, background .15s;
    }
    #topnav a:hover {
      color: #fff;
      border-color: #475569;
    }
    #topnav a.active {
      color: var(--accent);
      border-color: var(--accent);
      background: rgba(14,165,233,.08);
    }

    /* name */
    #hero h1 {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: #fff;
      letter-spacing: -.5px;
      line-height: 1.1;
      margin-bottom: 10px;
    }

    /* short tagline */
    #hero .tagline {
      font-size: 1rem;
      color: #94a3b8;
      max-width: 600px;
      line-height: 1.6;
      margin-bottom: 22px;
    }

    /* contact row */
    #hero .contacts {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 18px;
      font-size: .82rem;
    }

    #hero .contacts a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid transparent;
    }
    #hero .contacts a:hover {
      border-bottom-color: var(--accent);
    }

    #hero .contacts .ph {
      color: #475569;   /* slate-600 */
    }

    /* ── Content wrapper ─────────────────────────────────────────── */
    #content {
      max-width: 860px;
      margin: 0 auto;
      padding: 44px 20px 64px;
    }

    /* ── Section ─────────────────────────────────────────────────── */
    .section { margin-bottom: 44px; }

    .section-title {
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .section-title::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* ── About ───────────────────────────────────────────────────── */
    .about-text {
      font-size: .97rem;
      color: var(--text);
      line-height: 1.75;
      max-width: 720px;
    }

    /* ── Skills ──────────────────────────────────────────────────── */
    .skill-groups {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .skill-group {
      display: grid;
      grid-template-columns: 168px 1fr;
      gap: 0 16px;
      align-items: start;
    }

    .skill-group-name {
      font-size: .82rem;
      font-weight: 700;
      color: var(--muted);
      padding-top: 3px;
    }

    .skill-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }

    .pill {
      display: inline-block;
      font-size: .75rem;
      background: var(--pill-bg);
      color: var(--pill-fg);
      padding: .2em .65em;
      border-radius: 999px;
      line-height: 1.6;
      font-weight: 500;
    }

    /* ── Languages ───────────────────────────────────────────────── */
    .lang-pills { display: flex; flex-wrap: wrap; gap: 8px; }

    .lang-pill {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 6px 12px;
      font-size: .82rem;
    }

    .lang-name { font-weight: 600; color: var(--text); }
    .lang-level {
      font-size: .72rem;
      color: #fff;
      background: var(--accent);
      padding: .1em .45em;
      border-radius: 999px;
      font-weight: 600;
      letter-spacing: .03em;
    }

    /* ── Certifications ──────────────────────────────────────────── */
    .cert-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .cert-item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 14px;
    }

    .cert-badge {
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      padding: .25em .6em;
      border-radius: 4px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .cert-badge.coursera { background: #f3f6ff; color: #0056d2; border: 1px solid #c7d7f5; }
    .cert-badge.udemy    { background: #fff3f0; color: #a435f0; border: 1px solid #e8c8f8; }
    .cert-badge.other    { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }

    .cert-body { flex: 1; min-width: 0; }

    .cert-title {
      font-size: .88rem;
      font-weight: 600;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      display: block;
    }

    .cert-title:hover { color: var(--accent-d); }

    .cert-meta {
      font-size: .75rem;
      color: var(--muted);
      margin-top: 1px;
    }

    .cert-year {
      font-size: .75rem;
      color: #cbd5e1;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* ── Project cards ───────────────────────────────────────────── */
    .proj-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .proj-card {
      background: #fff;
      border: 1px solid var(--border);
      border-top: 3px solid var(--accent);
      border-radius: 4px;
      padding: 16px 18px;
    }

    .proj-card-name {
      font-weight: 700;
      font-size: .95rem;
      color: var(--text);
      margin-bottom: 2px;
    }

    .proj-card-meta {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      margin-bottom: 8px;
    }

    .proj-card-tech {
      font-size: .75rem;
      color: var(--muted);
    }

    .proj-card-date {
      font-size: .75rem;
      color: #cbd5e1;   /* slate-300 */
      white-space: nowrap;
    }

    /* ── Experience timeline ─────────────────────────────────────── */
    .timeline { list-style: none; }

    .tl-item {
      display: grid;
      grid-template-columns: 8px 1fr;
      gap: 0 18px;
      margin-bottom: 24px;
    }

    .tl-item:last-child { margin-bottom: 0; }

    /* colored left bar */
    .tl-bar {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 5px;
    }

    .tl-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    .tl-line {
      width: 2px;
      flex: 1;
      background: var(--border);
      margin-top: 4px;
    }

    .tl-item:last-child .tl-line { display: none; }

    .tl-body {}

    .tl-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 2px 10px;
      margin-bottom: 2px;
    }

    .tl-title {
      font-weight: 700;
      font-size: .95rem;
      color: var(--text);
    }

    .tl-date {
      font-size: .78rem;
      color: #cbd5e1;
      white-space: nowrap;
    }

    .tl-company {
      font-size: .85rem;
      color: var(--accent-d);
      font-weight: 600;
      margin-bottom: 6px;
    }

    /* ── Education (compact two-col) ─────────────────────────────── */
    .edu-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }

    .edu-item {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: 0 18px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--border);
    }

    .edu-item:last-child { border-bottom: none; padding-bottom: 0; }

    .edu-dates {
      font-size: .78rem;
      color: #cbd5e1;
      padding-top: 3px;
    }

    .edu-degree {
      font-weight: 700;
      font-size: .9rem;
      color: var(--text);
    }

    .edu-inst {
      font-size: .82rem;
      color: var(--muted);
      margin-bottom: 3px;
    }

    .edu-details {
      font-size: .8rem;
      color: #94a3b8;
    }

    /* ── Bullets ─────────────────────────────────────────────────── */
    ul.bullets { list-style: none; padding: 0; margin-top: 6px; }

    ul.bullets li {
      position: relative;
      padding-left: 14px;
      font-size: .85rem;
      color: #475569;   /* slate-600 */
      line-height: 1.55;
      margin-bottom: 4px;
    }

    ul.bullets li::before {
      content: "›";
      position: absolute;
      left: 0;
      color: var(--accent);
      font-weight: bold;
    }

    ul.bullets li strong { color: var(--text); }
    ul.bullets li em     { font-style: italic; }
    ul.bullets li code   {
      font-family: "SFMono-Regular", Consolas, monospace;
      font-size: .83em;
      background: #f1f5f9;
      padding: .05em .3em;
      border-radius: 3px;
    }

    /* ── Footer ──────────────────────────────────────────────────── */
    #footer {
      font-size: .72rem;
      color: #cbd5e1;
      margin-top: 48px;
      padding-top: 16px;
      border-top: 1px solid var(--border);
    }

    #footer a { color: #94a3b8; }

    /* ── Responsive ──────────────────────────────────────────────── */
    @media (max-width: 600px) {
      .proj-grid { grid-template-columns: 1fr; }
      .skill-group { grid-template-columns: 1fr; gap: 4px 0; }
      .edu-item { grid-template-columns: 1fr; gap: 2px; }
      #topnav .site-name { display: none; }
      .cert-title { white-space: normal; }
    }
  </style>
</head>
<body>

<!-- ══ HERO ══════════════════════════════════════════════════════════ -->
<div id="hero">
  <div id="hero-inner">

    <div id="topnav">
      <div class="nav-links">
        <a href="index.html" class="{{ 'active' if lang == 'en' else '' }}">EN</a>
        <a href="es.html" class="{{ 'active' if lang == 'es' else '' }}">ES</a>
      </div>
      <div class="nav-links">
        <a href="{{ 'index.html' if lang == 'en' else 'es.html' }}" class="active">cv</a>
        <a href="posts.html">posts</a>
      </div>
    </div>

    <h1>{{ person.name }}</h1>

    <div class="contacts">
      {% if person.email %}
        <a href="mailto:{{ person.email }}">{{ person.email }}</a>
      {% endif %}
      {% if person.linkedin %}
        <a href="{{ person.linkedin }}" target="_blank">LinkedIn</a>
      {% endif %}
      {% if person.github %}
        <a href="{{ person.github }}" target="_blank">GitHub</a>
      {% endif %}
      {% if person.website %}
        <a href="{{ person.website }}" target="_blank">{{ person.website }}</a>
      {% endif %}
      {% if person.phone %}
        <span class="ph">{{ person.phone }}</span>
      {% endif %}
    </div>

  </div>
</div>

<!-- ══ CONTENT ═══════════════════════════════════════════════════════ -->
<div id="content">

  <!-- About -->
  {% if summary %}
  <div class="section">
    <h2 class="section-title">About</h2>
    <p class="about-text">{{ summary }}</p>
  </div>
  {% endif %}

  <!-- Skills -->
  {% if tech_skills %}
  <div class="section">
    <h2 class="section-title">Skills</h2>
    <div class="skill-groups">
      {% for group in tech_skills %}
      <div class="skill-group">
        <span class="skill-group-name">{{ group.category }}</span>
        <div class="skill-pills">
          {% for tag in group.tags %}
          <span class="pill">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Languages -->
  {% if lang_tags %}
  <div class="section">
    <h2 class="section-title">Languages</h2>
    <div class="lang-pills">
      {% for entry in lang_tags %}
      {%- set parts = entry.split('(') %}
      {%- set lang  = parts[0].strip() %}
      {%- set level = parts[1].rstrip(')').strip() if parts|length > 1 else '' %}
      <div class="lang-pill">
        <span class="lang-name">{{ lang }}</span>
        {% if level %}<span class="lang-level">{{ level }}</span>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Certifications -->
  {% if certifications %}
  <div class="section">
    <h2 class="section-title">Certifications</h2>
    <div class="cert-list">
      {% for cert in certifications %}
      {%- set badge_class = cert.platform | lower if cert.platform | lower in ['coursera','udemy'] else 'other' %}
      <div class="cert-item">
        <span class="cert-badge {{ badge_class }}">{{ cert.platform }}</span>
        <div class="cert-body">
          {% if cert.url %}
          <a class="cert-title" href="{{ cert.url }}" target="_blank">{{ cert.title }}</a>
          {% else %}
          <span class="cert-title">{{ cert.title }}</span>
          {% endif %}
          <div class="cert-meta">{{ cert.provider }}{% if cert.comment %} &mdash; <span style="font-style:italic;">{{ cert.comment }}</span>{% endif %}</div>
        </div>
        <span class="cert-year">{{ cert.year }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Projects -->
  {% if projects %}
  <div class="section">
    <h2 class="section-title">Projects</h2>
    <div class="proj-grid">
      {% for proj in projects %}
      <div class="proj-card">
        <div class="proj-card-meta">
          <div class="proj-card-name">{{ proj.name }}</div>
          <div class="proj-card-date">{{ proj.dates }}</div>
        </div>
        {% if proj.tech %}
        <div class="proj-card-tech">{{ proj.tech }}</div>
        {% endif %}
        {% if proj.bullets %}
        <ul class="bullets">
          {% for b in proj.bullets %}<li>{{ b | safe_html }}</li>{% endfor %}
        </ul>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Experience -->
  {% if experience %}
  <div class="section">
    <h2 class="section-title">Experience</h2>
    <ul class="timeline">
      {% for job in experience %}
      <li class="tl-item">
        <div class="tl-bar">
          <div class="tl-dot"></div>
          <div class="tl-line"></div>
        </div>
        <div class="tl-body">
          <div class="tl-head">
            <div class="tl-title">{{ job.title }}</div>
            <div class="tl-date">{{ job.dates }}</div>
          </div>
          <div class="tl-company">
            {{ job.company }}{% if job.location %} &middot; <span style="font-weight:400; color:var(--muted);">{{ job.location }}</span>{% endif %}
          </div>
          {% if job.bullets %}
          <ul class="bullets">
            {% for b in job.bullets %}<li>{{ b | safe_html }}</li>{% endfor %}
          </ul>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <!-- Education -->
  {% if education %}
  <div class="section">
    <h2 class="section-title">Education</h2>
    <ul class="edu-list">
      {% for edu in education %}
      <li class="edu-item">
        <div class="edu-dates">{{ edu.dates }}</div>
        <div>
          <div class="edu-degree">{{ edu.degree }}</div>
          <div class="edu-inst">{{ edu.institution }}{% if edu.location %} &middot; {{ edu.location }}{% endif %}</div>
          {% if edu.details %}<div class="edu-details">{{ edu.details | safe_html }}</div>{% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  <div id="footer">
    built automatically from <a href="../cv/cv.tex">cv.tex</a> &mdash; cv-automat
  </div>

</div>
</body>
</html>
